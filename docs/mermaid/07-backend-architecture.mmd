---
title: 后端 FastAPI 架构
---
graph TB
    subgraph Entry["入口 main.py"]
        direction TB
        SystemdMode["systemd 模式<br/>start_fastapi_systemd()"]
        ForegroundMode["前台模式<br/>multiprocessing.Process"]
        FastAPIProc["FastAPI Process<br/>uvicorn 127.0.0.1:8001"]
        CeleryProc["Celery Worker Process<br/>线程池并发2"]
        FlowerProc["Flower 监控面板<br/>端口8000"]
    end

    subgraph InitConfig["exit.py init_config()"]
        direction TB
        StartupClean["启动清理<br/>所有用户 isonline=false"]
        AutoSeedRoutes["自动扫描路由权限<br/>auto_seed_route_permissions"]
        ExceptionHandler["全局异常处理<br/>StarletteHTTPException<br/>RequestValidationError"]
        MiddlewareChain["中间件注册链"]
        StaticMount["静态文件挂载"]
        RouteReg["路由注册"]
        DBInit["数据库初始化 _init_table()"]
    end

    subgraph Middleware["中间件链 (由内到外)"]
        direction LR
        M1["RequestLogMiddleware<br/>请求日志记录"]
        M2["RoutePermissionMiddleware<br/>动态路由权限检查"]
        M3["StaticAuthMiddleware<br/>静态文件鉴权"]
        M4["CORSMiddleware<br/>跨域处理"]
        M1 --> M2 --> M3 --> M4
    end

    subgraph Routes["路由模块"]
        direction TB

        subgraph UserInfo["/api/user/status"]
            Login["POST /token 登录"]
            Register["POST /VerificationCode 注册验证码"]
            Refresh["POST /refresh/token 刷新Token"]
            Logout["POST /logout 登出"]
        end

        subgraph SukinOS["/api/sukinos"]
            Upload["POST /app/upload 上传应用"]
            AppList["GET /app/appList 应用列表"]
            Search["GET /app/search 搜索"]
            LocalDev["/localdev 本地开发 SSE"]
        end

        subgraph Permission["/api/system/permission"]
            Registry["GET/POST /registry<br/>权限注册池"]
            Actors["PUT /registry/{id}/actors<br/>黑白名单"]
            Menus["GET/PUT /menus<br/>菜单权限"]
            RoutesPerm["GET/PUT /routes-permission<br/>路由权限"]
            Role["GET/POST /role<br/>角色管理"]
            SysApps["GET/PUT /system-apps<br/>POST/DELETE system-apps<br/>系统APP放权"]
            Power["GET/PUT /registry-power<br/>注册权"]
            Whitelist["GET/PUT /middleware-whitelist<br/>中间件白名单"]
        end

        subgraph SystemMgr["/api/system 其他"]
            Config["/systemconfig 系统配置"]
            Status["/status 系统监控"]
            AppMgmt["/sukinos 应用审核"]
            UserMgmt["/usermanage 用户管理"]
        end

        subgraph SocketApi["WebSocket /ws"]
            WSConnect["/{user_id} 连接"]
            Heartbeat["心跳 35s"]
            LoginTrack["时间追踪"]
        end
    end

    subgraph Auth["Auth.py 认证模块"]
        direction TB
        JwtCreate["create_access_token() 30min<br/>create_refresh_token() 7天"]
        VerifyAuth["verify_auth() 工厂"]
        SilentRefresh["静默刷新"]
        RequireRoot["@RequireRoot() 装饰器"]
        Permission["权限位验证"]
    end

    subgraph Database["数据层"]
        direction TB
        SQLAlchemy["SQLAlchemy ORM"]
        MySQL_[(MySQL 数据库)]
        RedisCache[("Redis 验证码")]
    end

    Entry --> InitConfig
    InitConfig --> Middleware
    Middleware --> Routes
    Routes --> Auth
    Auth --> Database
    Routes --> Database