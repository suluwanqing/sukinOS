---
title: 后端 FastAPI 架构
---
graph TB
    subgraph Entry["入口 main.py"]
        direction TB
        SystemdMode["systemd 模式<br/>start_fastapi_systemd()"]
        ForegroundMode["前台模式<br/>multiprocessing.Process"]
        FastAPIProc["FastAPI Process<br/>uvicorn 127.0.0.1:8001"]
        CeleryProc["Celery Worker Process<br/>线程池并发2"]
        FlowerProc["Flower 监控面板<br/>端口8000"]
    end

    subgraph InitConfig["exit.py init_config()"]
        direction TB
        StartupClean["启动清理<br/>所有用户 isonline=false"]
        ExceptionHandler["全局异常处理<br/>StarletteHTTPException<br/>RequestValidationError"]
        MiddlewareChain["中间件注册链"]
        StaticMount["静态文件挂载"]
        RouteReg["路由注册"]
        DBInit["数据库初始化 _init_table()"]
    end

    subgraph Middleware["中间件链 (由内到外)"]
        direction LR
        M1["RequestLogMiddleware<br/>请求日志记录"]
        M2["StaticAuthMiddleware<br/>静态文件鉴权"]
        M3["CORSMiddleware<br/>跨域处理"]
        M1 --> M2 --> M3
    end

    subgraph Routes["路由模块"]
        direction TB

        subgraph UserInfo["/api/user"]
            Login["POST /login 登录"]
            Register["POST /register 注册"]
            Logout["POST /logout 登出"]
            Refresh["POST /refresh 刷新Token"]
            Info["GET /info 用户信息"]
            Update["PUT /update 更新信息"]
            Avatar["POST /avatar 上传头像"]
        end

        subgraph SukinOS["/api/sukinos"]
            Upload["POST /app/upload 上传应用"]
            UpdateApp["POST /app/update 更新应用"]
            AppList["GET /app/appList 应用列表"]
            Search["GET /app/searchApp 搜索"]
            MyUpload["GET /app/myUpload 我的上传"]
            Delete["POST /app/delete 删除应用"]
            CheckUpdate["POST /app/checkUpdates 检查更新"]
            LocalDev["/localdev 本地开发 SSE"]
        end

        subgraph SocketApi["WebSocket /ws"]
            WSConnect["/{user_id} WebSocket 连接"]
            Heartbeat["心跳检测 35s"]
            LoginTrack["登录时间追踪"]
            LogoutTrack["登出时间统计"]
            KickUser["管理员强制断开"]
        end

        subgraph LocationSystem["/api/system"]
            Config["配置管理"]
            Status["系统状态监控"]
            UpdateLog["更新日志"]
            RequestLog["请求日志查询"]
            AppManage["应用审核管理"]
        end
    end

    subgraph Auth["Auth.py 认证模块"]
        direction TB
        JwtCreate["create_access_token() 30min<br/>create_refresh_token() 7天"]
        VerifyAuth["verify_auth() 工厂函数<br/>4阶段认证流程"]
        SilentRefresh["静默 Token 刷新"]
        Permission["权限模式<br/>superuser | role | power(位运算)"]
        PasswordHash["bcrypt 密码哈希<br/>passlib CryptContext"]
    end

    subgraph Database["数据层"]
        direction TB
        SQLAlchemy["SQLAlchemy ORM"]
        MySQL_[(MySQL 数据库)]
        RedisCache[("Redis 缓存<br/>验证码/会话")]
        ConnectionPool["连接池<br/>pool_size + overflow"]
    end

    Entry --> InitConfig
    InitConfig --> Middleware
    Middleware --> Routes
    Routes --> Auth
    Auth --> Database
    Routes --> Database
